# =============================================================================
# 🚀 Agentic AI Immersion Day - Environment Configuration
# =============================================================================
# This file contains all environment variables needed for the workshop.
# Copy this to .env and fill in your actual values.
# =============================================================================

# =============================================================================
# 🔐 AZURE AUTHENTICATION (Required for all notebooks)
# =============================================================================
TENANT_ID=<your-azure-tenant-id>
AZURE_SUBSCRIPTION_ID=<your-azure-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group-name>
AZURE_PROJECT_NAME=<your-ai-foundry-project-name>

# =============================================================================
# 🤖 Microsoft Foundry PROJECT (Required for azure-ai-agents/ notebooks)
# =============================================================================
# Used by: 1-basics, 2-code_interpreter, 3-file-search, 4-web-search,
#          5-agents-aisearch, 6-multi-agent, 7-mcp-tools, 8-foundry-IQ-agents,
#          9-agent-memory-search, all observability-and-evaluations notebooks

# Project endpoint
AI_FOUNDRY_PROJECT_ENDPOINT=<your-project-endpoint>
# Example: https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>

# Full resource ID (Required for 8-foundry-IQ-agents.ipynb - Foundry IQ)
PROJECT_RESOURCE_ID=<your-project-resource-id>
# Example: /subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>

# =============================================================================
# 🧠 MODEL DEPLOYMENTS (Required)
# =============================================================================
# Primary chat model - used across all notebooks
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Embedding model - for 8-foundry-IQ-agents, 9-agent-memory-search
EMBEDDING_MODEL_DEPLOYMENT_NAME=text-embedding-3-large

# =============================================================================
# 🤖 AGENT FRAMEWORK — FOUNDRY CLIENT CONVENTION (Required for agent-framework/)
# =============================================================================
# The agent-framework FoundryChatClient / AzureAIAgentsClient read these
# FOUNDRY_*-prefixed variables. Without FOUNDRY_MODEL the agent-framework
# notebooks fail with: "Model is required. Set via 'model' parameter or
# 'FOUNDRY_MODEL' environment variable." Set them to the same values as above.
FOUNDRY_PROJECT_ENDPOINT=<your-project-endpoint>
# Example: https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>
FOUNDRY_MODEL=gpt-4o

# =============================================================================
# 🔗 AZURE OPENAI DIRECT ACCESS (Required for Agent Framework)
# =============================================================================
# Used by: agent-framework/workflows/2-9, threads/1-3, middleware/1-9,
#          context_providers/, 5-agents-aisearch, red team security testing

AZURE_OPENAI_ENDPOINT=<your-azure-openai-endpoint>
# Example (OpenAI v1 surface): https://<your-foundry-resource>.openai.azure.com/openai/v1

# Entra ID (AAD) is the recommended auth and is REQUIRED when the account has
# local auth disabled. Leave the key blank to use `az login` + DefaultAzureCredential.
AZURE_OPENAI_API_KEY=

# Chat deployment name for Agent Framework workflows
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o

# =============================================================================
# 🔍 AZURE AI SEARCH / FOUNDRY IQ (Required for search & knowledge notebooks)
# =============================================================================
# Used by: 5-agents-aisearch, 8-foundry-IQ-agents, context_providers/2-azure_ai_search

AZURE_AI_SEARCH_ENDPOINT=<your-search-endpoint>
# Example: https://<your-search-resource>.search.windows.net

# Entra-first: leave the key BLANK to use az login + RBAC (the README grants the
# Search Index Data roles). Only set a key if your search service uses key auth.
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_API_VERSION=2025-03-01-preview
# Auth method is informational only (notebooks fall back to managed identity when the key is blank).
SEARCH_AUTHENTICATION_METHOD=rbac

# Index name for RAG demos
AZURE_SEARCH_INDEX_NAME=<your-index-name>

# =============================================================================
# 🔧 MCP TOOLS (Required for 7-mcp-tools.ipynb)
# =============================================================================
FOUNDRY_MCP_CONNECTION_ID=<your-mcp-connection-id>
# Get from AI Foundry Portal > Connections > MCP Server connection

# =============================================================================
# 🤖 HOSTED AGENTS (hosted-agents/ and AgentOps/)
# =============================================================================
# Foundry Toolbox with web_search + code_interpreter (used by the advisor agent)
TOOLBOX_NAME=benefits-advisor-tools
# Comma-separated Foundry skill names embedded by the advisor agent at startup
SKILL_NAMES=cost-analysis-methodology,regulatory-guidance

# =============================================================================
# 📊 OBSERVABILITY & TRACING (Required for observability notebooks)
# =============================================================================
# Enable content recording in traces (prompts/responses) - DEV/TEST ONLY
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true
AZURE_SDK_TRACING_IMPLEMENTATION=opentelemetry

# Enable sensitive data logging for agent-framework observability
ENABLE_SENSITIVE_DATA=true

# =============================================================================
#  OPTIONAL CONFIGURATION
# =============================================================================
# Application Insights (auto-discovered from project if not set)
# APPLICATIONINSIGHTS_CONNECTION_STRING=<your-app-insights-connection-string>

# OTLP Endpoint for Aspire Dashboard, Jaeger, etc.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=agentic-ai-workshop

# Console exporters for debugging
# ENABLE_CONSOLE_EXPORTERS=true
