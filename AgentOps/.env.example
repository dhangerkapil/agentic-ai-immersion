# AgentOps — Employee Benefits Concierge — local environment
# Copy to .env, or rely on the workshop root .env.
#
# When hosted in Foundry, FOUNDRY_PROJECT_ENDPOINT is injected automatically.
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Optional Foundry Toolbox (web_search + code_interpreter). Leave unset to run without tools.
TOOLBOX_NAME=benefits-concierge-tools
