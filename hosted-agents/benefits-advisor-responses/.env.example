# Employee Benefits Cost Advisor (Responses protocol) — local environment
# Copy to .env and fill in your values, or rely on the workshop root .env.
#
# When hosted in Foundry, FOUNDRY_PROJECT_ENDPOINT is injected automatically.
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# Foundry Toolbox containing web_search + code_interpreter (create it in the portal
# or via the SDK). Leave unset to run the agent without tools.
TOOLBOX_NAME=benefits-advisor-tools

# Comma-separated Foundry skill names to embed at startup (run provision_skills.py first).
SKILL_NAMES=cost-analysis-methodology,regulatory-guidance
