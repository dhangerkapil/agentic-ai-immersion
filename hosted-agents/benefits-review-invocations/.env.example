# Employee Benefits Review (Invocations protocol) — local environment
# Copy to .env and fill in your values, or rely on the workshop root .env.
#
# When hosted in Foundry, FOUNDRY_PROJECT_ENDPOINT is injected automatically.
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
